# ─────────────────────────────────────────────────────────────
# ShopMind 环境变量模板  (cp .env.example .env  后填真实值)
# 实际 .env 不入 git
# ─────────────────────────────────────────────────────────────

# === 必填:LLM / Embedding API Keys ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 可选:第三方兼容代理(留空走官方端点)
OPENAI_BASE_URL=

# === 可选:数据集路径(默认 dataset/sample/ 样品间;切全量改这两行)===
# 例:换全量 → INGEST_DATASET_DIR=./dataset/ecommerce_agent_dataset/
INGEST_DATASET_DIR=./dataset/sample/
STATIC_FILES_DIR=./dataset/sample/

# === 可选:运行时数据落盘位置 ===
SQLITE_PATH=./data/shopmind.db
QDRANT_PATH=./data/qdrant_storage/

# === 可选:服务基础 URL(image_url 拼接用,部署时改)===
BASE_URL=http://localhost:8000

# === 可选:默认 demo 用户(无 auth,X-User-Id header 默认值)===
DEFAULT_USER_ID=demo_user_1
