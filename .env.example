# ─────────────────────────────────────────────────────────────
# ShopMind 环境变量模板  (cp .env.example .env  后填真实值)
# 实际 .env 不入 git
# ─────────────────────────────────────────────────────────────

# === 必填:LLM + Embedding API Keys ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Embedding 默认走 Gemini(gemini-embedding-001, 3072 维, 带 task_type 区分 doc/query)
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_PROVIDER=gemini   # "gemini" | "openai"

# 可选 fallback:OpenAI 作为备选实现(EMBEDDING_PROVIDER=openai 时启用)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# === 可选:数据集路径(默认 dataset/sample/ 样品间;切全量改这两行)===
# 例:换全量 → INGEST_DATASET_DIR=./dataset/ecommerce_agent_dataset/
INGEST_DATASET_DIR=./dataset/sample/
STATIC_FILES_DIR=./dataset/sample/

# === 数据库 ===
# 跑 `docker-compose up -d` 起本地 Postgres,默认值即可
DATABASE_URL=postgresql+asyncpg://shopmind:shopmind@localhost:5432/shopmind
# 测试用 DB(跑 pytest 时用,跟 dev 数据隔离;首次起容器时 init SQL 自动建)
TEST_DATABASE_URL=postgresql+asyncpg://shopmind:shopmind@localhost:5432/shopmind_test

# === 可选:Qdrant 落盘位置(嵌入式模式,本地文件)===
QDRANT_PATH=./data/qdrant_storage/

# === 可选:服务基础 URL(image_url 拼接用,部署时改)===
BASE_URL=http://10.0.2.2:8000

# === 可选:默认 demo 用户(无 auth,X-User-Id header 默认值)===
DEFAULT_USER_ID=demo_user_1

# === 可选:Eval L3 Judge —— 豆包 via 火山引擎 Ark(跨模型评估,不填则 L3 跳过)===
# 火山控制台拿 API Key:https://console.volcengine.com/ark
# DOUBAO_JUDGE_MODEL 填"推理接入点 ID"(ep-xxxxxx)或直接填模型名(如 doubao-seed-1-6-250615)
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/
DOUBAO_JUDGE_MODEL=
