# ─────────────────────────────────────────────────────────────
# ShopMind .gitignore
# ─────────────────────────────────────────────────────────────

# Python
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
coverage.xml

# Build / dist
build/
dist/

# Secrets / env
.env*
!.env.example
secrets/
*.pem
*.key

# Runtime data (Qdrant 嵌入式落盘 + logs;Postgres 数据走 Docker volume)
data/
*.log
logs/

# Postgres dump(本地快速恢复用,可由 ingest + seed 重建,不入 git)
*.dump

# Datasets
dataset/sample/
dataset/sample/**

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Android (client/)
client/**/build/
client/**/.gradle/
client/**/.cxx/
client/**/captures/
client/**/local.properties
*.apk
*.aab
*.dex
*.iml

# Misc
*.bak
*.tmp
*.orig
