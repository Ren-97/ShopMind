{
  "_meta": {
    "version": "1.0",
    "description": "ShopMind eval ground truth. 20 cases × 9 scenarios × 4 categories.",
    "case_count": 20,
    "category_distribution": {
      "美妆": 6,
      "数码": 3,
      "服饰": 5,
      "食品": 4,
      "无类目": 2
    },
    "scenarios": [
      "基础推荐",
      "反选",
      "对比",
      "多轮上下文",
      "诚实拒答",
      "防幻觉对抗",
      "工具误触发回归",
      "L4 caveats 来源标注",
      "业务闭环"
    ],
    "field_schema": {
      "id": "唯一 ID,kebab-case",
      "scenario": "9 大场景之一(基础推荐 / 反选 / 对比 / 多轮上下文 / 诚实拒答 / 防幻觉对抗 / 工具误触发回归 / 场景化跨类目 / 业务闭环)",
      "category": "dataset 类目(美妆护肤 / 数码电子 / 服饰运动 / 食品饮料 / 无)",
      "tags": "core / edge / regression_guard / hallucination / business / multi_turn / session_state ...",
      "layers": "本 case 测试的 layer 子集 [1, 2, 3]",
      "user_id": "eval_user_1 (EvalAlice) / eval_user_2 (EvalBob) / eval_user_3 (EvalCharlie)",
      "profile_overrides": "可选,runner 跑前临时改 profile 字段(value=null 表示清空)",
      "session_state_seed": "可选,跑前注入 session_state(测多轮沉淀 / 代词指代)",
      "history": "可选,Anthropic messages 格式的前置对话(测多轮上下文)",
      "cart_seed": "可选,跑前往 cart_items 表写,业务闭环 case 用",
      "query": "本轮用户输入",
      "expected_query_type": "Planner 应输出的 query_type(L1)",
      "expected_hard_constraints": "完整精确匹配(L1)",
      "expected_hard_constraints_contains": "部分匹配,只检查指定字段(L1)",
      "expected_soft_preferences_contains": "soft preferences 部分匹配(L1)",
      "expected_referenced_product_ids": "id_lookup case 的 product_ids(L1)",
      "expected_referenced_count_min": "id_lookup 至少引用几个商品(L1)",
      "expected_tool_calls_include": "Agent 必须调用的 tool 名(L2)",
      "expected_tool_calls_not_include": "Agent 绝对不能调用的 tool(L2)",
      "expected_tool_calls_min": "至少调用 N 次 tool(场景化组合 case 用)",
      "expected_top_5_product_ids_contains": "Top-5 检索结果必须包含的 product_id(L2)",
      "expected_top_5_excludes_brands": "Top-5 检索结果不能出现的品牌(L2)",
      "expected_categories_covered_any": "跨类目 case:至少覆盖以下任一类目(L2)",
      "expected_no_match": "是否应触发 no_match 兜底(L2)",
      "expected_response_must_contain_any": "回复必须包含以下任一关键词(L2)",
      "expected_response_must_not_contain": "回复绝不能包含以下关键词(L2/L3)",
      "expected_profile_unchanged_fields": "跑完这些 profile 字段必须未变(L2)",
      "expected_cart_change": "购物车变化(L2)",
      "judge_focus": "L3 重点判分维度",
      "notes": "人类说明 + [VERIFY] 标记草稿期需 review 的具体值"
    }
  },

  "cases": [
    {
      "id": "basic_beauty_sensitive",
      "scenario": "基础推荐",
      "category": "美妆护肤",
      "tags": ["core", "filtered_semantic"],
      "layers": [1, 2, 3],
      "user_id": "eval_user_1",
      "query": "推荐适合敏感肌的保湿精华,500 以内",
      "expected_query_type": "filtered_semantic",
      "expected_hard_constraints": {
        "category": "美妆护肤",
        "sub_category": "精华",
        "suitable_skin": ["敏感肌"],
        "price_max": 500.0
      },
      "expected_soft_preferences_contains": {"effects": ["保湿"]},
      "expected_tool_calls_include": ["search_products"],
      "expected_no_match": false,
      "judge_focus": ["faithfulness", "source_attribution"],
      "notes": "标准 filtered_semantic 主路径。sub_category=「精华」已核 dataset 确认。"
    },

    {
      "id": "basic_digital_apple_structured",
      "scenario": "基础推荐",
      "category": "数码电子",
      "tags": ["core", "structured"],
      "layers": [1, 2],
      "user_id": "eval_user_2",
      "query": "8000 块以下在售的苹果手机",
      "expected_query_type": "structured",
      "expected_hard_constraints": {
        "category": "数码电子",
        "sub_category": "智能手机",
        "brand": "Apple 苹果",
        "price_max": 8000.0,
        "in_stock": true
      },
      "expected_tool_calls_include": ["search_products"],
      "expected_no_match": false,
      "notes": "纯属性筛选,无 text_query,走 structured 路径跳过 embedding。sub_category=「智能手机」、brand=「Apple 苹果」已核 dataset 确认。"
    },

    {
      "id": "negation_clothing_brand",
      "scenario": "反选",
      "category": "服饰运动",
      "tags": ["core", "negation"],
      "layers": [1, 2],
      "user_id": "eval_user_3",
      "query": "推荐双跑步鞋,不要 Nike 和阿迪达斯,1500 以内",
      "expected_query_type": "filtered_semantic",
      "expected_hard_constraints": {
        "category": "服饰运动",
        "sub_category": "跑步鞋",
        "brand_exclude": ["Nike", "阿迪达斯"],
        "price_max": 1500.0,
        "gender": "男"
      },
      "expected_tool_calls_include": ["search_products"],
      "expected_top_5_excludes_brands": ["Nike", "耐克", "阿迪达斯"],
      "notes": "反选必走 hard_constraints.brand_exclude,不能塞 text_query。"
    },

    {
      "id": "session_rejected_brands_food",
      "scenario": "反选",
      "category": "食品饮料",
      "tags": ["core", "multi_turn", "session_state"],
      "layers": [1, 2],
      "user_id": "eval_user_3",
      "session_state_seed": {
        "rejected_brands": ["红牛"],
        "current_topic": "功能饮料"
      },
      "query": "再推荐一款别的功能饮料",
      "expected_query_type": "filtered_semantic",
      "expected_hard_constraints_contains": {
        "brand_exclude": ["红牛"]
      },
      "expected_top_5_excludes_brands": ["红牛"],
      "notes": "上一轮已经 reject 红牛,本轮 query 没提,Planner 应自动从 session_state 并入 brand_exclude"
    },

    {
      "id": "compare_digital_two_brands",
      "scenario": "对比",
      "category": "数码电子",
      "tags": ["core", "id_lookup"],
      "layers": [1, 2],
      "user_id": "eval_user_2",
      "query": "iPhone 17 Pro 和华为 Pura 90 Pro 哪个拍照更好",
      "expected_query_type": "id_lookup",
      "expected_referenced_count_min": 2,
      "expected_tool_calls_include": ["compare_products"],
      "judge_focus": ["faithfulness"],
      "notes": "对比 query 应触发 id_lookup → Agent 先 search 拿到具体 product_id 再 compare。已核 dataset:p_digital_001=iPhone 17 Pro,p_digital_002=华为 Pura 90 Pro。"
