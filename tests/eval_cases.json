      "tags": ["core", "multi_turn", "id_lookup"],
      "layers": [1, 2],
      "user_id": "eval_user_3",
      "session_state_seed": {
        "last_shown_products": ["p_clothes_007", "p_clothes_008", "p_clothes_009"],
        "current_topic": "跑步鞋"
