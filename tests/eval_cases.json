      "query": "对比一下这三款",
      "expected_query_type": "id_lookup",
      "expected_referenced_product_ids": ["p_clothes_007", "p_clothes_008", "p_clothes_009"],
      "expected_tool_calls_include": ["compare_products"],
      "notes": "代词「这三款」+ last_shown_products 非空 → id_lookup。已核 dataset:p_clothes_007=耐克 Nike Air Zoom Pegasus 41,p_clothes_008=阿迪达斯 Ultraboost 5,p_clothes_009=HOKA Clifton 9。"
    },

    {
      "id": "pronoun_beauty_price",
      "scenario": "多轮上下文",
      "category": "美妆护肤",
      "tags": ["core", "multi_turn", "id_lookup"],
      "layers": [1, 2],
      "user_id": "eval_user_1",
      "session_state_seed": {
        "last_shown_products": ["p_beauty_001"]
